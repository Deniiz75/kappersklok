generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(BARBER)
  createdAt    DateTime @default(now())
  shop         Shop?
}

model Shop {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  contactName    String
  email          String          @unique
  phone          String?
  privatePhone   String?
  kvkNumber      String?
  country        String          @default("Nederland")
  street         String?
  houseNumber    String?
  city           String?
  postalCode     String?
  instagram      String?
  howFoundUs     String?
  language       String          @default("nl_NL")
  digibox        Boolean         @default(false)
  privateDomain  String?
  barbersCount   Int             @default(4)
  welcomePackage Boolean         @default(false)
  status         ShopStatus      @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String?         @unique
  user           User?           @relation(fields: [userId], references: [id])
  barbers        Barber[]
  services       Service[]
  businessHours  BusinessHours[]
  appointments   Appointment[]
  reviews        Review[]
  payments       Payment[]
  favorites      Favorite[]
}

model Barber {
  id           String        @id @default(cuid())
  name         String
  shopId       String
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
}

model Service {
  id           String        @id @default(cuid())
  name         String
  duration     Int
  price        Int
  shopId       String
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  active       Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
}

model BusinessHours {
  id        String  @id @default(cuid())
  shopId    String
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  closed    Boolean @default(false)

  @@unique([shopId, dayOfWeek])
}

model Appointment {
  id            String            @id @default(cuid())
  shopId        String
  shop          Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barberId      String
  barber        Barber            @relation(fields: [barberId], references: [id])
  serviceId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  date          DateTime          @db.Date
  startTime     String
  endTime       String
  customerName  String
  customerEmail String
  customerPhone String?
  status        AppointmentStatus @default(CONFIRMED)
  notes         String?
  cancelToken   String?           @unique @default(cuid())
  recurring     Boolean           @default(false)
  recurringWeeks Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Review {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId String?  @unique
  customerName  String
  customerEmail String
  rating        Int      // 1-5
  comment       String?
  approved      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Payment {
  id          String        @id @default(cuid())
  shopId      String
  shop        Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  amount      Int           // centen
  description String
  status      PaymentStatus @default(PAID)
  period      String        // "2026-03" (maand)
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())
}

model Customer {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
}

model Favorite {
  id            String   @id @default(cuid())
  customerEmail String
  shopId        String
  customer      Customer @relation(fields: [customerEmail], references: [email], onDelete: Cascade)
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([customerEmail, shopId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum Role {
  ADMIN
  BARBER
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
