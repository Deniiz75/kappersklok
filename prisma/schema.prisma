generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(BARBER)
  createdAt    DateTime @default(now())
  shop         Shop?
}

model Shop {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  contactName    String
  email          String     @unique
  phone          String?
  privatePhone   String?
  kvkNumber      String?
  country        String     @default("Nederland")
  street         String?
  houseNumber    String?
  city           String?
  postalCode     String?
  instagram      String?
  howFoundUs     String?
  language       String     @default("nl_NL")
  digibox        Boolean    @default(false)
  privateDomain  String?
  barbersCount   Int        @default(4)
  welcomePackage Boolean    @default(false)
  status         ShopStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String?    @unique
  user           User?      @relation(fields: [userId], references: [id])
  barbers        Barber[]
}

model Barber {
  id        String   @id @default(cuid())
  name      String
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum Role {
  ADMIN
  BARBER
}
