{
  "name": "kappersklok",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@kappersklok/web",
    "dev:mobile": "turbo dev --filter=@kappersklok/mobile",
    "build:web": "turbo build --filter=@kappersklok/web"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
